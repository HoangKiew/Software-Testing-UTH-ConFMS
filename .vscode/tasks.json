{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Vite Dev Server",
      "type": "shell",
      "command": "npm run dev -- --open",
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
