        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"score\": 9,\n  \"publicComment\": \"Updated comment\"\n}"
        },
        "url": {
          "raw": "http://localhost:3004/api/reviewer/assignments/:id/review",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3004",
          "path": ["api","reviewer","assignments",":id","review"]
        }
      }
    },
    {
