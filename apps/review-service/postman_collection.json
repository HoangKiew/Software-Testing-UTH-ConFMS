    "description": "Collection for testing review-service endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Review",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"score\": 8,\n  \"publicComment\": \"Good work\",\n  \"privateComment\": \"Notes\"\n}"
        },
        "url": {
          "raw": "http://localhost:3004/api/reviewer/assignments/:id/review",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3004",
          "path": ["api","reviewer","assignments",":id","review"]
        }
      }
    },
    {
