# ===========================================
# UTH ConFMS - Environment Variables Template
# ===========================================
# HƯỚNG DẪN: Copy file này thành .env và điền thông tin thật
#   Windows: copy .env.example .env
#   Linux/Mac: cp .env.example .env
# ===========================================

# --- EMAIL (Gmail App Password) ---
# Tạo App Password tại: https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- SUPABASE (File Storage cho submission-service) ---
# Tạo project tại: https://supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET_NAME=submission
